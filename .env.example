# Database
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading123
POSTGRES_DB=trading_db
DATABASE_URL=postgresql+asyncpg://trading:trading123@postgres:5432/trading_db

# Redis
REDIS_URL=redis://redis:6379/0

# Bybit (for public price data only, no API keys needed)
BYBIT_TESTNET=false

# Cryptorg API (for actual trading)
CRYPTORG_WEBHOOK_URL=https://api.cryptorg.io/webhook
CRYPTORG_API_KEY=your_cryptorg_api_key
CRYPTORG_SECRET=your_cryptorg_secret

# Backend
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
